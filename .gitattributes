# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly define text files (just in case auto-detection fails)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.svg text eol=lf

# Explicitly declare binary files so Git never attempts to modify their line endings
# (This protects your character assets!)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary